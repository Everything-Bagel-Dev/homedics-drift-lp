    },
    {
      "type": "text",
      "id": "headline",
      "label": "Section headline",
      "default": "Give her more good days."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Section subhead",
      "default": "Mother's Day is May 11. Drift is the gift that keeps giving — every evening, every morning, every quiet moment she finally gets to herself."
    },
    {
      "type": "header",
