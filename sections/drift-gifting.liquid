    },
    {
      "type": "text",
      "id": "item_1_badge",
      "label": "Badge text",
      "default": "$299.99"
    },
    {
      "type": "header",
      "content": "Gift Item 2 — Drift 16\""
    },
    {
      "type": "text",
      "id": "item_2_name",
      "label": "Item name",
      "default": "Drift 16\""
    },
    {
      "type": "text",
      "id": "item_2_desc",
      "label": "Item description",
      "default": "For the home she loves"
    },
    {
      "type": "text",
      "id": "item_2_compare_price",
      "label": "Compare at price",
      "default": "$399.99"
    },
    {
      "type": "text",
      "id": "item_2_sale_price",
      "label": "Sale price",
      "default": "$299.99"
    },
    {
      "type": "header",
      "content": "Gift Item 3 — Drift 21\""
    },
    {
      "type": "text",
      "id": "item_3_name",
      "label": "Item name",
      "default": "Drift 21\""
    },
    {
      "type": "text",
      "id": "item_3_desc",
      "label": "Item description",
      "default": "For the mom who deserves the room"
    },
    {
      "type": "text",
      "id": "item_3_compare_price",
      "label": "Compare at price",
      "default": "$499.99"
    },
    {
      "type": "text",
      "id": "item_3_sale_price",
      "label": "Sale price",
      "default": "$374.99"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop Mother's Day Gifts"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "header",
      "content": "Lifestyle Image"
    },
    {
      "type": "image_picker",
      "id": "gifting_image",
      "label": "Lifestyle photo",
      "info": "Woman 38–48, natural light, Drift in situ. Warm, calm. NOT pink-washed or overly staged."
    }
  ],
  "presets": [
    {
      "name": "Drift — Gifting (Mother's Day)"
    }
  ]
}
{% endschema %}
