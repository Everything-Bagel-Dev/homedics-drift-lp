{% comment %}
  drift-product-grid.liquid
  Section 3 — Product Comparison Grid
  Homedics Drift × Mental Health Awareness Month 2026

  Includes:
  - Section headline + subhead
  - 3 product cards (Drift 10" / 16" / 21")
  - Live Shopify product objects for pricing/availability
  - Tag pills: Most Popular (green) / On Sale (red)
  - Feature bullet lists
  - Hover: card lifts, glow brightens
  - Anchor: id="drift-products"
{% endcomment %}

{{ 'drift-mham.css' | asset_url | stylesheet_tag }}

<section class="drift-lp drift-products" id="drift-products">
  <div class="drift-container">

    <div class="drift-products__header">
      <h2 class="drift-products__headline">{{ section.settings.headline }}</h2>
      <p class="drift-products__subhead">{{ section.settings.subhead }}</p>
    </div>

    <div class="drift-products__grid">

      {%- comment %} ======= CARD 1: Drift 10" Premium Wood ======= {%- endcomment %}
      {%- assign product_1 = all_products[section.settings.product_1_handle] %}
      <div class="drift-product-card">

        <div class="drift-product-card__img-wrap">
          {%- if section.settings.product_1_image != blank %}
            {{ section.settings.product_1_image
              | image_url: width: 700
              | image_tag:
                class: 'drift-product-card__img',
                alt: section.settings.product_1_image.alt | default: 'Homedics Drift 10 Premium Wood',
                loading: 'lazy',
                width: 700
            }}
          {%- elsif product_1.featured_image %}
            {{ product_1.featured_image
              | image_url: width: 700
              | image_tag:
                class: 'drift-product-card__img',
                alt: product_1.featured_image.alt | default: product_1.title,
                loading: 'lazy',
                width: 700
            }}
          {%- else %}
            <div class="drift-product-card__img-placeholder">
              [Product image: Drift 10" in bedroom/desk lifestyle setting]
            </div>
          {%- endif %}

          <span class="drift-product-card__tag drift-product-card__tag--popular">
            {{ section.settings.product_1_tag }}
          </span>
        </div>

        <div class="drift-product-card__body">
          <p class="drift-product-card__name">{{ section.settings.product_1_name }}</p>
          <h3 class="drift-product-card__headline">{{ section.settings.product_1_headline }}</h3>
          <p class="drift-product-card__desc">{{ section.settings.product_1_desc }}</p>

          <ul class="drift-product-card__features" aria-label="Key features">
            {%- for i in (1..4) %}
              {%- assign feature_key = 'product_1_feature_' | append: i %}
              {%- assign feature_val = section.settings[feature_key] %}
              {%- if feature_val != blank %}
                <li class="drift-product-card__feature">{{ feature_val }}</li>
              {%- endif %}
            {%- endfor %}
          </ul>

          <div class="drift-product-card__pricing">
            {%- if product_1 != blank and product_1.available %}
              <span class="drift-product-card__price">{{ product_1.price | money }}</span>
            {%- else %}
              <span class="drift-product-card__price">{{ section.settings.product_1_price }}</span>
            {%- endif %}
          </div>

          <a
            href="{{ section.settings.product_1_url | default: product_1.url }}"
            class="drift-btn drift-btn--dark drift-btn--full"
          >
            {{ section.settings.product_1_cta }}
          </a>
        </div>

      </div>

      {%- comment %} ======= CARD 2: Drift 16" ======= {%- endcomment %}
      {%- assign product_2 = all_products[section.settings.product_2_handle] %}
      <div class="drift-product-card">

        <div class="drift-product-card__img-wrap">
          {%- if section.settings.product_2_image != blank %}
            {{ section.settings.product_2_image
              | image_url: width: 700
              | image_tag:
                class: 'drift-product-card__img',
                alt: section.settings.product_2_image.alt | default: 'Homedics Drift 16',
                loading: 'lazy',
                width: 700
            }}
          {%- elsif product_2.featured_image %}
            {{ product_2.featured_image
              | image_url: width: 700
              | image_tag:
                class: 'drift-product-card__img',
                alt: product_2.featured_image.alt | default: product_2.title,
                loading: 'lazy',
                width: 700
            }}
          {%- else %}
            <div class="drift-product-card__img-placeholder">
              [Product image: Drift 16" in living room / shared bedroom]
            </div>
          {%- endif %}

          {%- comment %} Sale tag removed per Jeff feedback — pricing block below shows strikethrough price {%- endcomment %}
        </div>

        <div class="drift-product-card__body">
          <p class="drift-product-card__name">{{ section.settings.product_2_name }}</p>
          <h3 class="drift-product-card__headline">{{ section.settings.product_2_headline }}</h3>
          <p class="drift-product-card__desc">{{ section.settings.product_2_desc }}</p>

          <ul class="drift-product-card__features" aria-label="Key features">
            {%- for i in (1..4) %}
              {%- assign feature_key = 'product_2_feature_' | append: i %}
              {%- assign feature_val = section.settings[feature_key] %}
              {%- if feature_val != blank %}
                <li class="drift-product-card__feature">{{ feature_val }}</li>
              {%- endif %}
            {%- endfor %}
          </ul>

          <div class="drift-product-card__pricing">
            {%- if product_2 != blank and product_2.compare_at_price_max > product_2.price_min %}
              <span class="drift-product-card__price drift-product-card__price--sale">
                {{ product_2.price_min | money }}
              </span>
              <span class="drift-product-card__price-compare">
                {{ product_2.compare_at_price_max | money }}
              </span>
            {%- elsif product_2 != blank %}
              <span class="drift-product-card__price">{{ product_2.price_min | money }}</span>
            {%- else %}
              <span class="drift-product-card__price drift-product-card__price--sale">
                {{ section.settings.product_2_price }}
              </span>
              {%- if section.settings.product_2_compare_price != blank %}
                <span class="drift-product-card__price-compare">
                  {{ section.settings.product_2_compare_price }}
                </span>
              {%- endif %}
            {%- endif %}
          </div>

          <a
            href="{{ section.settings.product_2_url | default: product_2.url }}"
            class="drift-btn drift-btn--dark drift-btn--full"
          >
            {{ section.settings.product_2_cta }}
          </a>
        </div>

      </div>

      {%- comment %} ======= CARD 3: Drift 21" ======= {%- endcomment %}
      {%- assign product_3 = all_products[section.settings.product_3_handle] %}
      <div class="drift-product-card">

        <div class="drift-product-card__img-wrap">
          {%- if section.settings.product_3_image != blank %}
            {{ section.settings.product_3_image
              | image_url: width: 700
              | image_tag:
                class: 'drift-product-card__img',
                alt: section.settings.product_3_image.alt | default: 'Homedics Drift 21',
                loading: 'lazy',
                width: 700
            }}
          {%- elsif product_3.featured_image %}
            {{ product_3.featured_image
              | image_url: width: 700
              | image_tag:
                class: 'drift-product-card__img',
                alt: product_3.featured_image.alt | default: product_3.title,
                loading: 'lazy',
                width: 700
            }}
          {%- else %}
            <div class="drift-product-card__img-placeholder">
              [Product image: Drift 21" as statement piece in living room]
            </div>
          {%- endif %}

          {%- comment %} Sale tag removed per Jeff feedback — pricing block below shows strikethrough price {%- endcomment %}
        </div>

        <div class="drift-product-card__body">
          <p class="drift-product-card__name">{{ section.settings.product_3_name }}</p>
          <h3 class="drift-product-card__headline">{{ section.settings.product_3_headline }}</h3>
          <p class="drift-product-card__desc">{{ section.settings.product_3_desc }}</p>

          <ul class="drift-product-card__features" aria-label="Key features">
            {%- for i in (1..4) %}
              {%- assign feature_key = 'product_3_feature_' | append: i %}
              {%- assign feature_val = section.settings[feature_key] %}
              {%- if feature_val != blank %}
                <li class="drift-product-card__feature">{{ feature_val }}</li>
              {%- endif %}
            {%- endfor %}
          </ul>

          <div class="drift-product-card__pricing">
            {%- if product_3 != blank and product_3.compare_at_price_max > product_3.price_min %}
              <span class="drift-product-card__price drift-product-card__price--sale">
                {{ product_3.price_min | money }}
              </span>
              <span class="drift-product-card__price-compare">
                {{ product_3.compare_at_price_max | money }}
              </span>
            {%- elsif product_3 != blank %}
              <span class="drift-product-card__price">{{ product_3.price_min | money }}</span>
            {%- else %}
              <span class="drift-product-card__price drift-product-card__price--sale">
                {{ section.settings.product_3_price }}
              </span>
              {%- if section.settings.product_3_compare_price != blank %}
                <span class="drift-product-card__price-compare">
                  {{ section.settings.product_3_compare_price }}
                </span>
              {%- endif %}
            {%- endif %}
          </div>

          <a
            href="{{ section.settings.product_3_url | default: product_3.url }}"
            class="drift-btn drift-btn--dark drift-btn--full"
          >
            {{ section.settings.product_3_cta }}
          </a>
        </div>

      </div>

    </div>{%- comment %} /.drift-products__grid {%- endcomment %}

  </div>
</section>

{% schema %}
{
  "name": "Drift — Product Grid",
  "tag": "section",
  "class": "shopify-section--drift-products",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Section headline",
      "default": "Three sizes. One purpose."
    },
