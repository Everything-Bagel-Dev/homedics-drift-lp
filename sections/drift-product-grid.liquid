      "type": "text",
      "id": "subhead",
      "label": "Section subhead",
      "default": "Find the drift that fits your space — and your day."
    },
    {
      "type": "header",
      "content": "Card 1 — Drift 10\" Premium Wood"
    },
    {
      "type": "text",
      "id": "product_1_handle",
