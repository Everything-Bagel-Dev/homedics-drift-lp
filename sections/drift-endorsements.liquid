{% comment %}
  drift-endorsements.liquid
  Section 4 — Doctor Endorsements
  Homedics Drift × Mental Health Awareness Month 2026

  Includes:
  - Dark background section header
  - 2×2 quote card grid
  - Press logo bar
  - ⚠️ All doctor quotes are placeholder — INSERT APPROVED QUOTES from Homedics asset library.
    Do NOT publish with placeholder text. Pull verbatim from Dr. Schwartz, Dr. Rosenstock,
    Dr. Gonzalez, Dr. Nieves before going live.
{% endcomment %}

{{ 'drift-mham.css' | asset_url | stylesheet_tag }}

<section class="drift-lp drift-endorsements" id="drift-endorsements">
  <div class="drift-container">

    <div class="drift-endorsements__header">
      <span class="drift-eyebrow drift-eyebrow--light">{{ section.settings.eyebrow }}</span>
      <h2 class="drift-endorsements__headline">{{ section.settings.headline }}</h2>
      <p class="drift-endorsements__subhead">{{ section.settings.subhead }}</p>
    </div>

    {%- comment %} 2×2 Quote Card Grid {%- endcomment %}
    <div class="drift-endorsements__grid">

      {%- comment %} Card 1 {%- endcomment %}
      <article class="drift-quote-card">
        <blockquote class="drift-quote-card__quote">
          {{ section.settings.quote_1_text }}
        </blockquote>
        <div class="drift-quote-card__meta">
          <p class="drift-quote-card__name">{{ section.settings.quote_1_name }}</p>
          <p class="drift-quote-card__credential">{{ section.settings.quote_1_credential }}</p>
        </div>
      </article>

      {%- comment %} Card 2 {%- endcomment %}
      <article class="drift-quote-card">
        <blockquote class="drift-quote-card__quote">
          {{ section.settings.quote_2_text }}
        </blockquote>
        <div class="drift-quote-card__meta">
          <p class="drift-quote-card__name">{{ section.settings.quote_2_name }}</p>
          <p class="drift-quote-card__credential">{{ section.settings.quote_2_credential }}</p>
        </div>
      </article>

      {%- comment %} Card 3 {%- endcomment %}
      <article class="drift-quote-card">
        <blockquote class="drift-quote-card__quote">
          {{ section.settings.quote_3_text }}
        </blockquote>
        <div class="drift-quote-card__meta">
          <p class="drift-quote-card__name">{{ section.settings.quote_3_name }}</p>
          <p class="drift-quote-card__credential">{{ section.settings.quote_3_credential }}</p>
        </div>
      </article>

      {%- comment %} Card 4 {%- endcomment %}
      <article class="drift-quote-card">
        <blockquote class="drift-quote-card__quote">
          {{ section.settings.quote_4_text }}
        </blockquote>
        <div class="drift-quote-card__meta">
          <p class="drift-quote-card__name">{{ section.settings.quote_4_name }}</p>
          <p class="drift-quote-card__credential">{{ section.settings.quote_4_credential }}</p>
        </div>
      </article>

    </div>{%- comment %} /.drift-endorsements__grid {%- endcomment %}

    {%- comment %} Press Bar {%- endcomment %}
    {%- if section.settings.press_bar_enabled %}
    <div class="drift-endorsements__press">
      <p class="drift-endorsements__press-label">{{ section.settings.press_label }}</p>
      <div class="drift-endorsements__press-logos">

        {%- for i in (1..4) %}
          {%- assign logo_key  = 'press_logo_'  | append: i %}
          {%- assign alt_key   = 'press_alt_'   | append: i %}
          {%- assign label_key = 'press_label_' | append: i %}
          {%- assign logo      = section.settings[logo_key] %}
          {%- assign alt       = section.settings[alt_key] %}
          {%- assign label     = section.settings[label_key] %}

          {%- if logo != blank %}
            {{ logo
              | image_url: width: 200
              | image_tag:
                class: 'drift-endorsements__press-logo',
                alt: alt | default: label,
                loading: 'lazy',
                width: 200
            }}
          {%- elsif label != blank %}
            <span class="drift-endorsements__press-logo-placeholder">{{ label }}</span>
          {%- endif %}
        {%- endfor %}

      </div>
    </div>
    {%- endif %}

  </div>
</section>

