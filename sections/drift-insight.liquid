{% comment %}
  drift-insight.liquid
  Section 2 — The Insight / Emotional Hook
  Homedics Drift × Mental Health Awareness Month 2026

  Layout: Image on left, copy on right (left-aligned)
  - Large serif italic pull quote
  - 3-paragraph body copy connecting MHA theme to Drift
  - Warm linen background
  - Image: lifestyle shot (STS-400_0931.jpg from Air: https://app.air.inc/a/c8d305320)
{% endcomment %}

{{ 'drift-mham.css' | asset_url | stylesheet_tag }}

<section class="drift-lp drift-insight" id="drift-insight">
  <div class="drift-insight__inner drift-container">

    {%- comment %} LEFT: Lifestyle image {%- endcomment %}
    <div class="drift-insight__image">
      {%- if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 800 | image_tag: class: 'drift-insight__img', loading: 'lazy' }}
      {%- else %}
        <div class="drift-insight__image-placeholder">
          <span>Lifestyle Image</span>
        </div>
      {%- endif %}
    </div>

    {%- comment %} RIGHT: Copy block — left-aligned {%- endcomment %}
    <div class="drift-insight__copy">

      <blockquote class="drift-insight__quote">
        {{ section.settings.pull_quote }}
      </blockquote>

      <div class="drift-insight__body">
        <p>{{ section.settings.body_paragraph_1 }}</p>
        <p>{{ section.settings.body_paragraph_2 }}</p>
        <p>{{ section.settings.body_paragraph_3 }}</p>
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Drift — Insight",
  "tag": "section",
  "class": "shopify-section--drift-insight",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle image (left side)",
      "info": "Use STS-400_0931.jpg from Air: https://app.air.inc/a/c8d305320"
    },
    {
      "type": "textarea",
      "id": "pull_quote",
      "label": "Pull quote (serif italic display)",
      "default": "\u201cA good day isn't always big. Sometimes it's five quiet minutes watching patterns move \u2014 and finally, your mind goes still.\u201d"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_1",
      "label": "Body paragraph 1",
      "default": "Mental Health America's 2026 theme asks a simple question: What does a good day look like for you?"
    },
    {
      "type": "textarea",
      "id": "body_paragraph_2",
      "label": "Body paragraph 2",
      "default": "For millions of people, the answer starts at home. With a ritual. With a moment of intentional calm."
    },
    {
      "type": "textarea",
      "id": "body_paragraph_3",
      "label": "Body paragraph 3",
      "default": "Drift was built for exactly that."
    }
  ],
  "presets": [
    {
      "name": "Drift — Insight"
    }
  ]
}
{% endschema %}
