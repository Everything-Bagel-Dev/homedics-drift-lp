{% comment %}
  drift-app-experience.liquid
  Section 5 — App Experience (Split-Screen)
  Homedics Drift × Mental Health Awareness Month 2026

  Includes:
  - Split-screen layout: phone mockup LEFT, copy block RIGHT
  - Ambient glow animation behind phone mockup
  - Feature bullet list
  - Primary (Shop Drift) + Secondary (Download App) CTAs
  - Deep Navy background
{% endcomment %}

{{ 'drift-mham.css' | asset_url | stylesheet_tag }}

<section class="drift-lp drift-app" id="drift-app">
  <div class="drift-app__inner drift-container">

    {%- comment %} LEFT: Phone mockup with ambient glow {%- endcomment %}
    <div class="drift-app__mockup">

      {%- comment %} Ambient RGBIC glow — purely CSS {%- endcomment %}
      <div class="drift-app__glow-bg" aria-hidden="true"></div>

      {%- if section.settings.app_phone_image != blank %}
        {{ section.settings.app_phone_image
          | image_url: width: 600
          | image_tag:
            class: 'drift-app__phone',
            alt: section.settings.app_phone_image.alt | default: 'Homedics Drift app on iPhone — ambient light control',
            loading: 'lazy',
            width: 600
        }}
      {%- else %}
        <div class="drift-app__phone-placeholder">
          [Phone mockup: Real Drift app UI<br>in clean phone frame —<br>not illustrated]
        </div>
      {%- endif %}

    </div>

    {%- comment %} RIGHT: Copy block {%- endcomment %}
    <div class="drift-app__copy">

      <span class="drift-eyebrow drift-eyebrow--light">{{ section.settings.eyebrow }}</span>

      <h2 class="drift-app__headline">{{ section.settings.headline }}</h2>

      <p class="drift-app__body">{{ section.settings.body }}</p>

      <ul class="drift-app__features" aria-label="App features">
        {%- for i in (1..3) %}
          {%- assign feature_key = 'feature_' | append: i %}
          {%- assign feature_val = section.settings[feature_key] %}
          {%- if feature_val != blank %}
            <li class="drift-app__feature">
              <span class="drift-app__feature-dot" aria-hidden="true"></span>
              <span>{{ feature_val }}</span>
            </li>
          {%- endif %}
        {%- endfor %}
      </ul>

      <div class="drift-app__ctas">
        <a
          href="{{ section.settings.cta_primary_url }}"
          class="drift-btn drift-btn--primary"
          aria-label="{{ section.settings.cta_primary_text }}"
        >
          {{ section.settings.cta_primary_text }}
        </a>
        {%- if section.settings.cta_secondary_url != blank %}
          <a
            href="{{ section.settings.cta_secondary_url }}"
            class="drift-btn drift-btn--secondary"
            aria-label="{{ section.settings.cta_secondary_text }}"
          >
            {{ section.settings.cta_secondary_text }}
          </a>
        {%- endif %}
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Drift — App Experience",
  "tag": "section",
  "class": "shopify-section--drift-app",
  "settings": [
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Homedics Drift App"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Your calm. Your control."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body paragraph",
      "default": "drift connects to the Homedics Drift app — giving you complete control over color, brightness, motion speed, and pre-set moods. Schedule your evening wind-down. Wake up to a soft sunrise. Your good day, programmed the night before."
    },
    {
      "type": "header",
      "content": "Feature Bullets"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Millions of color combinations — set the exact mood you need"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Schedule lighting modes — sunrise wake-up, evening wind-down"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "WiFi control (Drift 10\") — adjust from anywhere in your home"
    },
    {
      "type": "header",
      "content": "CTAs"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA text",
      "default": "Shop Drift"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA text",
      "default": "Download the App"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA URL",
      "info": "Link to App Store or Homedics app page. Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Phone Mockup Image"
    },
    {
      "type": "image_picker",
      "id": "app_phone_image",
      "label": "App phone mockup",
      "info": "Real Drift app UI in a clean phone frame. Not illustrated. Min 600px wide."
    }
  ],
  "presets": [
    {
      "name": "Drift — App Experience"
    }
  ]
}
{% endschema %}
