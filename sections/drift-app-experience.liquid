{% comment %}
  drift-app-experience.liquid
  Section 5 — App Experience (Split-Screen)
  Homedics Drift × Mental Health Awareness Month 2026

  Jeff Laine design feedback applied (April 2026):
  - Layout: lifestyle image LEFT, copy block RIGHT (was phone mockup left)
  - Primary lifestyle image: ST-400-CE_LS3.png from Air (https://app.air.inc/a/ca30e8d92)
  - Secondary image option: ST-180-AW_PDP06.png from Air (https://app.air.inc/a/c6940d172)
  - Two image_picker settings; primary takes precedence, secondary as fallback
{% endcomment %}

{{ 'drift-mham.css' | asset_url | stylesheet_tag }}

<section class="drift-lp drift-app" id="drift-app">
  <div class="drift-app__inner drift-container">

    {%- comment %} LEFT: Lifestyle image (replaced phone mockup per Jeff feedback) {%- endcomment %}
    <div class="drift-app__lifestyle">

      {%- if section.settings.lifestyle_image != blank %}
        {{ section.settings.lifestyle_image
          | image_url: width: 700
          | image_tag:
            class: 'drift-app__lifestyle-img',
            alt: section.settings.lifestyle_image.alt | default: 'Homedics Drift ambient light — lifestyle in home setting',
            loading: 'lazy',
            width: 700
        }}
      {%- elsif section.settings.lifestyle_image_alt != blank %}
        {{ section.settings.lifestyle_image_alt
          | image_url: width: 700
          | image_tag:
            class: 'drift-app__lifestyle-img',
            alt: section.settings.lifestyle_image_alt.alt | default: 'Homedics Drift ambient light — lifestyle in home setting',
            loading: 'lazy',
            width: 700
        }}
      {%- else %}
        <div class="drift-app__lifestyle-placeholder">
          [Primary lifestyle image:<br>
          ST-400-CE_LS3.png from Air<br>
          https://app.air.inc/a/ca30e8d92<br><br>
          Alternative:<br>
          ST-180-AW_PDP06.png<br>
          https://app.air.inc/a/c6940d172]
        </div>
      {%- endif %}

    </div>

    {%- comment %} RIGHT: Copy block {%- endcomment %}
    <div class="drift-app__copy">

      <span class="drift-eyebrow drift-eyebrow--light">{{ section.settings.eyebrow }}</span>

      <h2 class="drift-app__headline">{{ section.settings.headline }}</h2>

      <p class="drift-app__body">{{ section.settings.body }}</p>

      <ul class="drift-app__features" aria-label="App features">
        {%- for i in (1..3) %}
          {%- assign feature_key = 'feature_' | append: i %}
          {%- assign feature_val = section.settings[feature_key] %}
          {%- if feature_val != blank %}
            <li class="drift-app__feature">
              <span class="drift-app__feature-dot" aria-hidden="true"></span>
              <span>{{ feature_val }}</span>
            </li>
          {%- endif %}
        {%- endfor %}
      </ul>

      <div class="drift-app__ctas">
        <a
          href="{{ section.settings.cta_primary_url }}"
          class="drift-btn drift-btn--primary"
          aria-label="{{ section.settings.cta_primary_text }}"
        >
          {{ section.settings.cta_primary_text }}
        </a>
        {%- if section.settings.cta_secondary_url != blank %}
          <a
            href="{{ section.settings.cta_secondary_url }}"
            class="drift-btn drift-btn--secondary"
            aria-label="{{ section.settings.cta_secondary_text }}"
          >
            {{ section.settings.cta_secondary_text }}
          </a>
        {%- endif %}
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Drift — App Experience",
  "tag": "section",
  "class": "shopify-section--drift-app",
  "settings": [
    {
      "type": "header",
      "content": "Lifestyle Images",
      "info": "Image shows on LEFT. Primary takes precedence; secondary used if primary is blank."
    },
    {
      "type": "image_picker",
      "id": "lifestyle_image",
      "label": "Primary lifestyle image",
      "info": "Use ST-400-CE_LS3.png from Air: https://app.air.inc/a/ca30e8d92 — lifestyle shot of Drift in home setting."
    },
    {
      "type": "image_picker",
      "id": "lifestyle_image_alt",
      "label": "Secondary lifestyle image (fallback)",
      "info": "Alternative option: ST-180-AW_PDP06.png from Air: https://app.air.inc/a/c6940d172"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Homedics Drift App"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Your calm. Your control."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body paragraph",
      "default": "drift connects to the Homedics Drift app — giving you complete control over color, brightness, motion speed, and pre-set moods. Schedule your evening wind-down. Wake up to a soft sunrise. Your good day, programmed the night before."
    },
    {
      "type": "header",
      "content": "Feature Bullets"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Millions of color combinations — set the exact mood you need"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Schedule lighting modes — sunrise wake-up, evening wind-down"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "WiFi control (Drift 10\") — adjust from anywhere in your home"
    },
    {
      "type": "header",
      "content": "CTAs"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary CTA text",
      "default": "Shop Drift"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA text",
      "default": "Download the App"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA URL",
      "info": "Link to App Store or Homedics app page. Leave blank to hide."
    }
  ],
  "presets": [
    {
      "name": "Drift — App Experience"
    }
  ]
}
{% endschema %}
